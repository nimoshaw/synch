<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Server URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:hint="ws://192.168.1.100:8080"
            android:inputType="textUri"
            android:textColor="#E0E0E0"
            android:textColorHint="#546E7A"
            android:backgroundTint="#0F3460"
            android:padding="12dp" />

        <!-- Admin Token -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="管理员 Token"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAdminToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:hint="留空 = 无鉴权"
            android:inputType="textPassword"
            android:textColor="#E0E0E0"
            android:textColorHint="#546E7A"
            android:backgroundTint="#0F3460"
            android:padding="12dp" />

        <!-- Display Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="显示名称"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"
            android:hint="Android 用户"
            android:inputType="text"
            android:textColor="#E0E0E0"
            android:textColorHint="#546E7A"
            android:backgroundTint="#0F3460"
            android:padding="12dp" />

        <!-- Node ID (read-only) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="节点 ID (自动生成)"
            android:textColor="#90CAF9"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNodeId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:textColor="#78909C"
            android:backgroundTint="#0F3460"
            android:padding="12dp"
            android:enabled="false" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="测试连接"
                android:backgroundTint="#1A5276" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="保存配置"
                android:backgroundTint="#0F3460" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
