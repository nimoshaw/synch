# Production Environment
# 注意: 变量名需与 server/cmd/relay/main.go 中的 resolveConfig() 一致
SYNCH_MODE=production
SYNCH_LOG_LEVEL=warn
SYNCH_WS_PORT=:8080
SYNCH_DB_PATH=/data/relay_db
# 生产环境务必设置 Admin Token
SYNCH_ADMIN_TOKEN=${SYNCH_ADMIN_TOKEN:-changeme}
# 允许的 WebSocket Origin 列表 (逗号分隔, 空或 * 表示允许所有)
SYNCH_ALLOWED_ORIGINS=${SYNCH_ALLOWED_ORIGINS:-}
